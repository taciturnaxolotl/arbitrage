# Indiko OAuth2 Configuration
INDIKO_ISSUER=https://your-indiko-server.com
INDIKO_CLIENT_ID=ikc_your_client_id
INDIKO_CLIENT_SECRET=iks_your_client_secret  # required
INDIKO_REDIRECT_URL=http://localhost:8080/auth/callback

# Session encryption key (generate a random 32+ char string)
SESSION_SECRET=change-me-to-a-random-secret

# SQLite database path (default: controlplane.db)
DB_PATH=controlplane.db
